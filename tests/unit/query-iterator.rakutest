#| Unit tests for QueryIterator role
#| Tests QueryIterator role contract, Iterator extension, next() method, and Context integration
use Test;
use lib 'lib';

use Qwiratry::QueryIterator;
use Qwiratry::Context;

plan 14;

# =============================================================================
# Helper classes for testing
# =============================================================================

# Simple Context implementation for testing
my class TestContext does Context {
    has Int $.items-processed is rw = 0;
}

# Simple QueryIterator implementation that iterates over a list
my class ListIterator does QueryIterator {
    has @.items;
    has Int $!index = 0;
    
    method next(--> Mu) {
        if $!index >= @!items.elems {
            return Nil;
        }
        $.context.items-processed++;
        @!items[$!index++]
    }
}

# Empty QueryIterator that returns Nil immediately
my class EmptyIterator does QueryIterator {
    method next(--> Mu) { Nil }
}

# =============================================================================
# QueryIterator role basic tests
# =============================================================================

subtest 'QueryIterator role exists' => {
    plan 2;
    
    ok QueryIterator.^name eq 'QueryIterator', 'QueryIterator role exists';
    ok QueryIterator.HOW.^name ~~ /Metamodel/, 'QueryIterator is a proper role';
}

subtest 'QueryIterator extends Iterator' => {
    plan 2;
    
    my $ctx = TestContext.new;
    my $iter = EmptyIterator.new(context => $ctx);
    
    ok $iter ~~ Iterator, 'QueryIterator does Iterator role';
    ok $iter ~~ QueryIterator, 'Instance does QueryIterator role';
}

subtest 'Concrete class can compose QueryIterator' => {
    plan 3;
    
    my $ctx = TestContext.new;
    my $iter = ListIterator.new(
        context => $ctx,
        items => [1, 2, 3]
    );
    
    ok $iter.defined, 'Concrete class can be instantiated';
    ok $iter ~~ QueryIterator, 'Instance does QueryIterator role';
    ok $iter ~~ Iterator, 'Instance does Iterator role';
}

# =============================================================================
# Context integration tests
# =============================================================================

subtest 'QueryIterator receives Context via constructor' => {
    plan 3;
    
    my $ctx = TestContext.new;
    my $iter = ListIterator.new(
        context => $ctx,
        items => ['a', 'b']
    );
    
    ok $iter.context.defined, 'Context attribute is set';
    ok $iter.context ~~ Context, 'Context is correct type';
    ok $iter.context === $ctx, 'Context is the same object passed to constructor';
}

subtest 'Context is accessible during iteration' => {
    plan 3;
    
    my $ctx = TestContext.new;
    my $iter = ListIterator.new(
        context => $ctx,
        items => [1, 2, 3]
    );
    
    is $ctx.items-processed, 0, 'Initial count is 0';
    
    $iter.next;
    $iter.next;
    
    is $ctx.items-processed, 2, 'Context state updated during iteration';
    is $iter.context.items-processed, 2, 'Can access Context via iterator';
}

subtest 'Context required for construction' => {
    plan 1;
    
    dies-ok {
        EmptyIterator.new();  # No context provided
    }, 'Constructor fails without Context';
}

# =============================================================================
# next() method contract tests (per specification)
# =============================================================================

subtest 'next() returns values then Nil' => {
    plan 4;
    
    my $ctx = TestContext.new;
    my $iter = ListIterator.new(
        context => $ctx,
        items => ['x', 'y']
    );
    
    is $iter.next, 'x', 'First value returned';
    is $iter.next, 'y', 'Second value returned';
    ok !$iter.next.defined, 'Nil returned when exhausted';
    ok !$iter.next.defined, 'Nil returned consistently';
}

subtest 'Empty iterator returns Nil immediately' => {
    plan 2;
    
    my $ctx = TestContext.new;
    my $iter = EmptyIterator.new(context => $ctx);
    
    ok !$iter.next.defined, 'First next returns Nil';
    ok !$iter.next.defined, 'Subsequent calls return Nil';
}

subtest 'Multiple calls after exhaustion return Nil' => {
    plan 4;
    
    my $ctx = TestContext.new;
    my $iter = ListIterator.new(
        context => $ctx,
        items => [1]
    );
    
    $iter.next;  # Consume the single item
    
    ok !$iter.next.defined, 'First exhaustion check';
    ok !$iter.next.defined, 'Second exhaustion check';
    ok !$iter.next.defined, 'Third exhaustion check';
    ok !$iter.next.defined, 'Fourth exhaustion check';
}

# =============================================================================
# pull-one() bridge method tests (for Raku Iterator compatibility)
# =============================================================================

subtest 'pull-one() bridges to next() for Iterator protocol' => {
    plan 4;
    
    my $ctx = TestContext.new;
    my $iter = ListIterator.new(
        context => $ctx,
        items => ['a', 'b']
    );
    
    is $iter.pull-one, 'a', 'pull-one returns first value';
    is $iter.pull-one, 'b', 'pull-one returns second value';
    ok $iter.pull-one =:= IterationEnd, 'pull-one returns IterationEnd when exhausted';
    ok $iter.pull-one =:= IterationEnd, 'pull-one returns IterationEnd consistently';
}

# =============================================================================
# Independence tests
# =============================================================================

subtest 'Multiple iterators from same data are independent' => {
    plan 4;
    
    my @data = <a b c>;
    my $ctx1 = TestContext.new;
    my $ctx2 = TestContext.new;
    
    my $iter1 = ListIterator.new(context => $ctx1, items => @data);
    my $iter2 = ListIterator.new(context => $ctx2, items => @data);
    
    # Advance iter1 twice
    $iter1.next;
    $iter1.next;
    
    # iter2 should still be at start
    is $iter2.next, 'a', 'iter2 starts at beginning';
    is $iter1.next, 'c', 'iter1 continues from its position';
    
    is $ctx1.items-processed, 3, 'ctx1 tracks iter1 progress';
    is $ctx2.items-processed, 1, 'ctx2 tracks iter2 progress';
}

subtest 'Iterator can be used with for loop via pull-one bridge' => {
    plan 2;
    
    my $ctx = TestContext.new;
    my $iter = ListIterator.new(
        context => $ctx,
        items => [10, 20, 30]
    );
    
    my @collected;
    # Use Seq.new to create iterable from iterator (uses pull-one)
    for Seq.new($iter) -> $item {
        @collected.push($item);
    }
    
    is @collected.elems, 3, 'All items collected';
    is-deeply @collected, [10, 20, 30], 'Items in correct order';
}

subtest 'QueryIterator type can be used as constraint' => {
    plan 2;
    
    sub process-iterator(QueryIterator $iter) {
        $iter.next;
    }
    
    my $ctx = TestContext.new;
    my $iter = ListIterator.new(context => $ctx, items => [1]);
    
    lives-ok { process-iterator($iter) }, 'QueryIterator passes type constraint';
    is $ctx.items-processed, 1, 'Iterator was actually used';
}

subtest 'Both next() and pull-one() work correctly on same iterator' => {
    plan 4;
    
    my $ctx = TestContext.new;
    my $iter = ListIterator.new(
        context => $ctx,
        items => [1, 2, 3, 4]
    );
    
    is $iter.next, 1, 'next() returns first item';
    is $iter.pull-one, 2, 'pull-one() returns second item';
    is $iter.next, 3, 'next() returns third item';
    is $iter.pull-one, 4, 'pull-one() returns fourth item';
}

done-testing;

#| Unit tests for exception hierarchy
#| Tests X::Qwiratry::Walker and X::Qwiratry::UnknownQueryElement exceptions
use Test;

use Qwiratry::X;

plan 15;

# --- X::Qwiratry::Walker base exception tests ---

subtest 'X::Qwiratry::Walker can be created', {
    plan 3;
    my $ex = X::Qwiratry::Walker.new(message => 'Test error');
    ok $ex.defined, 'Exception created';
    is $ex.message, 'Test error', 'Message attribute accessible';
    is $ex.walker-type, 'Unknown', 'Walker-type has default value';
};

subtest 'X::Qwiratry::Walker accepts all attributes', {
    plan 2;
    my $ex = X::Qwiratry::Walker.new(
        message => 'Custom error',
        walker-type => 'TestWalker'
    );
    is $ex.message, 'Custom error', 'Custom message set';
    is $ex.walker-type, 'TestWalker', 'Custom walker-type set';
};

subtest 'X::Qwiratry::Walker can be thrown and caught', {
    plan 2;
    my $caught = False;
    my $caught-message = '';
    try {
        X::Qwiratry::Walker.new(message => 'Thrown error').throw;
        CATCH {
            when X::Qwiratry::Walker {
                $caught = True;
                $caught-message = .message;
            }
        }
    }
    ok $caught, 'Exception was caught';
    is $caught-message, 'Thrown error', 'Caught exception has correct message';
};

subtest 'X::Qwiratry::Walker gist is informative', {
    plan 1;
    my $ex = X::Qwiratry::Walker.new(
        message => 'Error message',
        walker-type => 'MyWalker'
    );
    like $ex.gist, /Error \s+ message/, 'Gist contains message';
};

subtest 'X::Qwiratry::Walker is an Exception', {
    plan 1;
    my $ex = X::Qwiratry::Walker.new(message => 'Test');
    ok $ex ~~ Exception, 'Is an Exception';
};

# --- X::Qwiratry::UnknownQueryElement exception tests ---

subtest 'X::Qwiratry::UnknownQueryElement can be created', {
    plan 4;
    my $ex = X::Qwiratry::UnknownQueryElement.new(
        message => 'Unknown element',
        query-ast => 'mock-ast'
    );
    ok $ex.defined, 'Exception created';
    is $ex.message, 'Unknown element', 'Message attribute accessible';
    is $ex.query-ast, 'mock-ast', 'Query-ast attribute accessible';
    is $ex.walker-type, 'Unknown', 'Inherits walker-type default';
};

subtest 'X::Qwiratry::UnknownQueryElement accepts all attributes', {
    plan 3;
    my $ex = X::Qwiratry::UnknownQueryElement.new(
        message => 'Cannot interpret',
        walker-type => 'TreeWalker',
        query-ast => 'complex-ast'
    );
    is $ex.message, 'Cannot interpret', 'Message set';
    is $ex.walker-type, 'TreeWalker', 'Walker-type set';
    is $ex.query-ast, 'complex-ast', 'Query-ast set';
};

subtest 'X::Qwiratry::UnknownQueryElement extends X::Qwiratry::Walker', {
    plan 2;
    my $ex = X::Qwiratry::UnknownQueryElement.new(message => 'Test');
    ok $ex ~~ X::Qwiratry::Walker, 'Is a X::Qwiratry::Walker';
    ok $ex ~~ Exception, 'Is an Exception';
};

subtest 'X::Qwiratry::UnknownQueryElement can be thrown and caught', {
    plan 3;
    my $caught = False;
    my $caught-ast = '';
    my $caught-message = '';
    try {
        X::Qwiratry::UnknownQueryElement.new(
            message => 'Unknown query',
            query-ast => 'test-ast'
        ).throw;
        CATCH {
            when X::Qwiratry::UnknownQueryElement {
                $caught = True;
                $caught-message = .message;
                $caught-ast = .query-ast;
            }
        }
    }
    ok $caught, 'Exception was caught';
    is $caught-message, 'Unknown query', 'Caught exception has correct message';
    is $caught-ast, 'test-ast', 'Caught exception has correct query-ast';
};

subtest 'X::Qwiratry::UnknownQueryElement can be caught as base type', {
    plan 1;
    my $caught = False;
    try {
        X::Qwiratry::UnknownQueryElement.new(message => 'Test').throw;
        CATCH {
            when X::Qwiratry::Walker {
                $caught = True;
            }
        }
    }
    ok $caught, 'UnknownQueryElement caught as Walker exception';
};

subtest 'X::Qwiratry::UnknownQueryElement gist is informative', {
    plan 2;
    my $ex = X::Qwiratry::UnknownQueryElement.new(
        message => 'Cannot handle',
        query-ast => 'test-ast'
    );
    like $ex.gist, /Cannot \s+ handle/, 'Gist contains message';
    like $ex.gist, /query\-ast/, 'Gist mentions query-ast';
};

# --- Diagnostic message tests ---

subtest 'Exception messages are non-empty', {
    plan 2;
    my $ex1 = X::Qwiratry::Walker.new(message => 'Error');
    my $ex2 = X::Qwiratry::UnknownQueryElement.new(message => 'Error');
    ok $ex1.gist.chars > 0, 'Walker gist is non-empty';
    ok $ex2.gist.chars > 0, 'UnknownQueryElement gist is non-empty';
};

subtest 'Exceptions can handle undefined query-ast', {
    plan 1;
    my $ex = X::Qwiratry::UnknownQueryElement.new(message => 'Test');
    lives-ok { $ex.gist }, 'Gist works with undefined query-ast';
};

subtest 'Exception attributes are accessible after catch', {
    plan 4;
    my ($msg, $type, $ast);
    try {
        X::Qwiratry::UnknownQueryElement.new(
            message => 'Access test',
            walker-type => 'AccessWalker',
            query-ast => 'access-ast'
        ).throw;
        CATCH {
            when X::Qwiratry::UnknownQueryElement {
                $msg = .message;
                $type = .walker-type;
                $ast = .query-ast;
            }
        }
    }
    is $msg, 'Access test', 'Message accessible in CATCH';
    is $type, 'AccessWalker', 'Walker-type accessible in CATCH';
    is $ast, 'access-ast', 'Query-ast accessible in CATCH';
    pass 'All attributes accessible';
};

subtest 'Multiple exceptions can be distinguished', {
    plan 2;
    my $is-unknown = False;
    my $is-base = False;
    
    try {
        X::Qwiratry::UnknownQueryElement.new(message => 'Unknown').throw;
        CATCH {
            when X::Qwiratry::UnknownQueryElement { $is-unknown = True }
            when X::Qwiratry::Walker { $is-base = True }
        }
    }
    ok $is-unknown, 'UnknownQueryElement caught specifically';
    nok $is-base, 'Base exception not triggered for specific';
};

done-testing;

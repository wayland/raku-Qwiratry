#| Unit tests for exception hierarchy
#| Tests X::Qwiratry::Walker and X::Qwiratry::UnknownQueryElement exceptions
use Test;

use lib 'lib';
use Qwiratry::X;

plan 16;

# =============================================================================
# T011: Unit tests for exception hierarchy
# =============================================================================

subtest 'X::Qwiratry::Walker base exception', {
    plan 6;
    
    # Test that X::Qwiratry::Walker can be created
    my $ex = X::Qwiratry::Walker.new(message => 'Test error');
    ok $ex.defined, 'Exception can be created';
    isa-ok $ex, Exception, 'Is an Exception';
    isa-ok $ex, X::Qwiratry::Walker, 'Is X::Qwiratry::Walker';
    
    # Test attributes
    is $ex.message, 'Test error', 'message attribute is accessible';
    is $ex.walker-type, 'Unknown', 'walker-type has default value';
    
    # Test with custom walker-type
    my $ex2 = X::Qwiratry::Walker.new(
        message => 'Custom error',
        walker-type => 'Tree::Walker::DFS'
    );
    is $ex2.walker-type, 'Tree::Walker::DFS', 'Custom walker-type is stored';
};

subtest 'X::Qwiratry::Walker throwing and catching', {
    plan 3;
    
    my $caught = False;
    my $caught-message;
    
    try {
        die X::Qwiratry::Walker.new(message => 'Thrown error');
        CATCH {
            when X::Qwiratry::Walker {
                $caught = True;
                $caught-message = .message;
            }
        }
    }
    
    ok $caught, 'Exception can be thrown and caught';
    is $caught-message, 'Thrown error', 'Message preserved when caught';
    
    # Test gist output
    my $ex = X::Qwiratry::Walker.new(message => 'Test', walker-type => 'TestWalker');
    like $ex.gist, /X\:\:Qwiratry\:\:Walker/, 'gist contains exception type';
};

subtest 'X::Qwiratry::UnknownQueryElement exception', {
    plan 7;
    
    # Test that X::Qwiratry::UnknownQueryElement can be created
    my $ex = X::Qwiratry::UnknownQueryElement.new(
        message => 'Unknown element',
        walker-type => 'TestWalker',
        query-ast => 'mock-ast'
    );
    ok $ex.defined, 'Exception can be created';
    isa-ok $ex, Exception, 'Is an Exception';
    isa-ok $ex, X::Qwiratry::Walker, 'Inherits from X::Qwiratry::Walker';
    isa-ok $ex, X::Qwiratry::UnknownQueryElement, 'Is X::Qwiratry::UnknownQueryElement';
    
    # Test attributes
    is $ex.message, 'Unknown element', 'message attribute inherited';
    is $ex.walker-type, 'TestWalker', 'walker-type attribute inherited';
    is $ex.query-ast, 'mock-ast', 'query-ast attribute is accessible';
};

subtest 'X::Qwiratry::UnknownQueryElement throwing and catching', {
    plan 4;
    
    my $caught = False;
    my $caught-ast;
    my $caught-as-base = False;
    
    # Test catching as specific type
    try {
        die X::Qwiratry::UnknownQueryElement.new(
            message => 'Cannot interpret',
            query-ast => 'test-ast'
        );
        CATCH {
            when X::Qwiratry::UnknownQueryElement {
                $caught = True;
                $caught-ast = .query-ast;
            }
        }
    }
    
    ok $caught, 'Exception can be thrown and caught';
    is $caught-ast, 'test-ast', 'query-ast preserved when caught';
    
    # Test catching as base type
    try {
        die X::Qwiratry::UnknownQueryElement.new(
            message => 'Test',
            query-ast => 'ast'
        );
        CATCH {
            when X::Qwiratry::Walker {
                $caught-as-base = True;
            }
        }
    }
    
    ok $caught-as-base, 'Can be caught as base X::Qwiratry::Walker';
    
    # Test gist output
    my $ex = X::Qwiratry::UnknownQueryElement.new(
        message => 'Test',
        query-ast => 'mock'
    );
    like $ex.gist, /UnknownQueryElement/, 'gist contains exception type';
};

# =============================================================================
# T012: Verify exception message formatting and attribute access
# =============================================================================

subtest 'Exception message formatting', {
    plan 4;
    
    my $ex = X::Qwiratry::Walker.new(
        message => 'Detailed error message',
        walker-type => 'Custom::Walker'
    );
    
    ok $ex.gist.contains('Detailed error message'), 'gist contains message';
    ok $ex.gist.contains('Custom::Walker'), 'gist contains walker-type';
    
    my $ex2 = X::Qwiratry::UnknownQueryElement.new(
        message => 'Unknown query element',
        walker-type => 'Tree::Walker',
        query-ast => 'RakuAST::Call'
    );
    
    ok $ex2.gist.contains('Unknown query element'), 'UnknownQueryElement gist contains message';
    ok $ex2.gist.contains('Tree::Walker'), 'UnknownQueryElement gist contains walker-type';
};

subtest 'Attribute access in CATCH block', {
    plan 5;
    
    my ($msg, $type, $ast);
    
    try {
        die X::Qwiratry::UnknownQueryElement.new(
            message => 'Error in CATCH test',
            walker-type => 'CATCH::Test::Walker',
            query-ast => 'sample-ast-node'
        );
        CATCH {
            when X::Qwiratry::UnknownQueryElement {
                $msg = .message;
                $type = .walker-type;
                $ast = .query-ast;
            }
        }
    }
    
    is $msg, 'Error in CATCH test', 'message accessible in CATCH';
    is $type, 'CATCH::Test::Walker', 'walker-type accessible in CATCH';
    is $ast, 'sample-ast-node', 'query-ast accessible in CATCH';
    ok $msg.defined, 'message is defined';
    ok $ast.defined, 'query-ast is defined';
};

subtest 'Exception with undefined query-ast', {
    plan 2;
    
    my $ex = X::Qwiratry::UnknownQueryElement.new(
        message => 'No AST provided'
    );
    
    nok $ex.query-ast.defined, 'query-ast can be undefined';
    like $ex.gist, /undefined/, 'gist handles undefined query-ast';
};

done-testing;
